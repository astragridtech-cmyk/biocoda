{
  "name": "biocoda-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "BioCoda: 30-year Biodiversity Net Gain (BNG) habitat monitoring with Earth observation and field verification (self-contained monorepo)",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "build": "pnpm -r --filter=./packages/* build",
    "test": "pnpm -r test",
    "test:core": "pnpm --filter @biocoda/adapters --filter @biocoda/shared test",
    "typecheck": "pnpm -r typecheck",
    "dev": "pnpm --filter @biocoda/web dev",
    "seed:print": "pnpm --filter @biocoda/db seed:print",
    "seed:sql": "pnpm --filter @biocoda/db seed:sql"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
