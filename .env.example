# BioCoda: local demo environment. No external keys required.
# docker-compose injects sensible defaults; copy to .env only if you override.

# Postgres + PostGIS (local container)
POSTGRES_USER=biocoda
POSTGRES_PASSWORD=biocoda
POSTGRES_DB=biocoda
DATABASE_URL=postgresql://biocoda:biocoda@db:5432/biocoda
# Production (Supabase): connect as the least-privilege biocoda_app role via the
# TRANSACTION pooler (6543) so Row-Level Security enforces tenant isolation.
# Run migrations with `pnpm --filter @biocoda/db migrate` (session/direct conn).
# See DEPLOY.md.
# DATABASE_URL=postgresql://biocoda_app.<ref>:<pw>@aws-1-<region>.pooler.supabase.com:6543/postgres

# EO worker (FastAPI)
EO_WORKER_URL=http://eo-worker:8000

# Real Earth observation (Copernicus Data Space Ecosystem / Sentinel Hub).
# Without these, EO uses the deterministic model. To pull live Sentinel-2 NDVI
# for parcels with geometry, register a free CDSE OAuth client and set all three.
# The client secret is server-side only; never expose it to the browser.
# CDSE_CLIENT_ID=sh-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# CDSE_CLIENT_SECRET=
# BIOCODA_EO_REAL=1

# Web app
# Comma-free single value; the dev role switcher overrides per request.
DEFAULT_TENANT=rb-natural-trust
DEFAULT_ROLE=responsible_body

# Digest email (Resend). Without a key, the digest is generated and logged but
# not delivered. Set both to actually email the state-of-portfolio digest.
# RESEND_API_KEY=
# BIOCODA_EMAIL_FROM=BioCoda <noreply@yourdomain>

# Plan ingestion (HMMP / LEMP / Biodiversity Gain Plan extraction)
# Without a key, the deterministic sample engine is used. To extract real plans
# with Claude (Opus 4.8), set both of these:
# ANTHROPIC_API_KEY=
# BIOCODA_PLAN_REAL=1

# Auth (Supabase). Set both to enable real email/password login; otherwise the
# login page offers a demo sign-in. Create a user in the Supabase dashboard.
# NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
#
# Social sign-in (Google + Microsoft) uses Supabase OAuth. No extra env here.
# Two different redirect URLs are involved, do not mix them up:
#  1. In Google Cloud / Microsoft Entra, register Supabase's callback as the
#     "authorized redirect URI":
#       https://<project>.supabase.co/auth/v1/callback
#  2. In Supabase > Authentication > URL Configuration, add the APP callback to
#     the Redirect URLs allow-list:
#       http://localhost:3011/auth/callback   (and your production /auth/callback)
# Then paste each provider's client ID + secret into Supabase > Authentication >
# Providers (Google, Azure) and toggle them on.

# --- Production target (not used by the local demo) ---
# Supabase service role (server-side admin), when wiring storage/admin tasks.
# SUPABASE_SERVICE_ROLE_KEY=
